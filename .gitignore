package com.superislam.app

import android.os.Bundle
import androidx.activity.ComponentActivity
import androidx.activity.compose.setContent
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.foundation.layout.*
import androidx.compose.ui.Modifier
import androidx.compose.ui.unit.dp
import androidx.compose.ui.graphics.Color

// ================= DESIGN =================
val Green = Color(0xFF00A884)

// ================= STATE =================
object AppState {
    var screen by mutableStateOf("HOME")
}

// ================= MAIN =================
class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent { App() }
    }
}

// ================= ROOT APP =================
@Composable
fun App() {
    MaterialTheme {
        when (AppState.screen) {
            "HOME" -> Home()
            "QURAN" -> Quran()
            "PRAYER" -> Prayer()
            "AI" -> AI()
            "CHAT" -> Chat()
        }
    }
}

// ================= HOME =================
@Composable
fun Home() {
    Column(
        Modifier.fillMaxSize().padding(16.dp)
    ) {
        Text("🕌 Islamic Super App", style = MaterialTheme.typography.headlineMedium)

        Spacer(Modifier.height(20.dp))

        MenuBtn("📖 Quran") { AppState.screen = "QURAN" }
        MenuBtn("🕌 Prayer & Athan") { AppState.screen = "PRAYER" }
        MenuBtn("🤖 AI Assistant") { AppState.screen = "AI" }
        MenuBtn("💬 Private Chat") { AppState.screen = "CHAT" }
    }
}

// ================= BUTTON =================
@Composable
fun MenuBtn(text: String, onClick: () -> Unit) {
    Button(
        onClick = onClick,
        colors = ButtonDefaults.buttonColors(containerColor = Green),
        modifier = Modifier.fillMaxWidth().padding(vertical = 6.dp)
    ) {
        Text(text)
    }
}

// ================= QURAN =================
val quran = listOf(
    "Al-Fatiha - In the name of Allah",
    "Al-Ikhlas - Say He is Allah the One",
    "Al-Falaq - Seek refuge in the Lord of dawn",
    "An-Nas - Seek refuge in mankind Lord"
)

@Composable
fun Quran() {
    Column(Modifier.fillMaxSize().padding(16.dp)) {
        Text("📖 Offline Quran")

        Spacer(Modifier.height(10.dp))

        quran.forEach {
            Text("• $it")
        }

        Back()
    }
}

// ================= PRAYER =================
@Composable
fun Prayer() {
    Column(Modifier.fillMaxSize().padding(16.dp)) {
        Text("🕌 Prayer Times")

        Spacer(Modifier.height(10.dp))

        Text("Fajr: 05:10")
        Text("Dhuhr: 12:30")
        Text("Asr: 15:45")
        Text("Maghrib: 18:20")
        Text("Isha: 19:40")

        Spacer(Modifier.height(20.dp))

        Button(onClick = { /* Athan logic later */ }) {
            Text("🔊 Play Athan")
        }

        Back()
    }
}

// ================= AI LOGIC =================
fun aiLogic(q: String): String {
    return when {
        q.contains("prayer", true) -> "Prayer is 5 times daily in Islam."
        q.contains("quran", true) -> "Quran has 114 Surahs."
        q.contains("allah", true) -> "Allah is One, without partner."
        else -> "I don't have an answer yet."
    }
}

// ================= AI SCREEN =================
@Composable
fun AI() {
    var input by remember { mutableStateOf("") }
    var output by remember { mutableStateOf("") }

    Column(Modifier.fillMaxSize().padding(16.dp)) {

        Text("🤖 Islamic AI (Offline)")

        Spacer(Modifier.height(10.dp))

        TextField(
            value = input,
            onValueChange = { input = it },
            modifier = Modifier.fillMaxWidth()
        )

        Spacer(Modifier.height(10.dp))

        Button(onClick = {
            output = aiLogic(input)
        }) {
            Text("Ask AI")
        }

        Spacer(Modifier.height(10.dp))

        Text(output)

        Back()
    }
}

// ================= CHAT =================
val messages = mutableStateListOf<String>()

@Composable
fun Chat() {
    var msg by remember { mutableStateOf("") }

    Column(Modifier.fillMaxSize().padding(16.dp)) {

        Text("💬 Private Chat")

        Spacer(Modifier.height(10.dp))

        messages.forEach {
            Text(it)
        }

        Spacer(Modifier.height(10.dp))

        TextField(
            value = msg,
            onValueChange = { msg = it },
            modifier = Modifier.fillMaxWidth()
        )

        Button(onClick = {
            if (msg.isNotBlank()) {
                messages.add("User: $msg")
                msg = ""
            }
        }) {
            Text("Send")
        }

        Back()
    }
}

// ================= BACK =================
@Composable
fun Back() {
    Spacer(Modifier.height(20.dp))

    Button(onClick = { AppState.screen = "HOME" }) {
        Text("⬅ Back")
    }
}